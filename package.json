{
  "name": "erabg",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "ERABG — free, private, in-browser background eraser with AI upscaling up to 4K.",
  "author": "Sandesh Thapa",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "electron:dev": "concurrently -k -n vite,electron -c blue,magenta \"vite\" \"wait-on http://localhost:5173 && VITE_DEV_SERVER_URL=http://localhost:5173 electron .\"",
    "electron:preview": "npm run build && electron .",
    "electron:build": "npm run build && electron-builder"
  },
  "devDependencies": {
    "@imgly/background-removal": "^1.7.0",
    "@tailwindcss/vite": "^4.3.1",
    "@tensorflow/tfjs": "~4.11.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@upscalerjs/esrgan-slim": "^1.0.0",
    "@vitejs/plugin-react": "^6.0.2",
    "concurrently": "^10.0.3",
    "electron": "^42.4.1",
    "electron-builder": "^26.15.3",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwindcss": "^4.3.1",
    "typescript": "^6.0.3",
    "upscaler": "^1.0.0",
    "vite": "^8.0.16",
    "wait-on": "^9.0.10"
  }
}
